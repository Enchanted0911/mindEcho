<view class="vip-page"><view class="vip-header"><view class="back-btn" bindtap="{{a}}">← 返回</view><text class="header-title">开通会员</text><view style="width:80rpx"/></view><scroll-view class="vip-scroll" scroll-y><view class="vip-hero"><text class="hero-emoji">👑</text><text class="hero-title">心屿会员</text><text class="hero-subtitle">解锁完整 AI 情绪陪伴体验</text><view wx:if="{{b}}" class="vip-status-badge"><text>✓ 已是会员</text></view></view><view class="benefits-section"><text class="section-title">会员专属权益</text><view class="benefits-grid"><view wx:for="{{c}}" wx:for-item="b" wx:key="d" class="benefit-card"><text class="benefit-emoji">{{b.a}}</text><text class="benefit-title">{{b.b}}</text><text class="benefit-desc">{{b.c}}</text></view></view></view><view class="plans-section"><text class="section-title">选择套餐</text><view class="plans-list"><view wx:for="{{d}}" wx:for-item="plan" wx:key="g" class="{{['plan-card', plan.h && 'plan-selected', plan.i && 'plan-popular']}}" bindtap="{{plan.j}}"><view wx:if="{{plan.a}}" class="plan-badge">{{plan.b}}</view><view class="plan-info"><text class="plan-label">{{plan.c}}</text><text class="plan-duration">{{plan.d}}</text></view><view class="plan-price-area"><text class="plan-price">¥{{plan.e}}</text><text class="plan-original">¥{{plan.f}}</text></view></view></view></view><view class="free-tip"><text class="free-tip-text">免费版每日 10 次对话，升级后无限制</text></view><view style="height:200rpx"/></scroll-view><view class="buy-footer"><view class="buy-price-info"><text class="buy-label">{{e}}</text><text class="buy-price">¥{{f}}</text></view><button class="buy-btn" loading="{{h}}" disabled="{{i}}" bindtap="{{j}}">{{g}}</button></view></view>