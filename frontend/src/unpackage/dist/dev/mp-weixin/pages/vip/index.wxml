<view class="vip-page"><view class="vip-header"><view class="back-btn" bindtap="{{a}}"><text class="back-icon">‹</text></view><text class="header-title">开通会员</text><view style="width:48rpx"/></view><scroll-view class="vip-scroll" scroll-y><view class="hero-area"><view class="hero-bg-glow"/><view class="hero-icon-wrap"><text class="hero-icon">👑</text><view class="hero-ring r1"/><view class="hero-ring r2"/></view><text class="hero-title">心屿会员</text><text class="hero-subtitle">解锁完整 AI 情绪陪伴体验</text><view wx:if="{{b}}" class="vip-active-badge"><text class="vip-active-dot"/><text class="vip-active-text">会员已激活</text></view></view><view class="benefits-area"><text class="area-label">会员专属权益</text><view class="benefits-grid"><view wx:for="{{c}}" wx:for-item="b" wx:key="d" class="benefit-card"><text class="benefit-icon">{{b.a}}</text><text class="benefit-title">{{b.b}}</text><text class="benefit-desc">{{b.c}}</text></view></view></view><view class="plans-area"><text class="area-label">选择套餐</text><view class="plans-list"><view wx:for="{{d}}" wx:for-item="plan" wx:key="k" class="{{['plan-card', plan.l && 'plan-selected']}}" bindtap="{{plan.m}}"><view class="{{['plan-radio', plan.b && 'radio-selected']}}"><view wx:if="{{plan.a}}" class="radio-dot"/></view><view class="plan-main"><view class="plan-name-row"><text class="plan-label">{{plan.c}}</text><view wx:if="{{plan.d}}" class="{{['plan-badge', plan.f && 'badge-recommend']}}"><text class="plan-badge-text">{{plan.e}}</text></view></view><text class="plan-duration">{{plan.g}}</text></view><view class="plan-price-block"><view class="plan-price-row"><text class="plan-price-unit">¥</text><text class="plan-price">{{plan.h}}</text></view><text class="plan-original">¥{{plan.i}}</text><text class="plan-per-day">约 ¥{{plan.j}}/天</text></view></view></view></view><view class="free-note"><text class="free-note-text">免费版每日对话次数有限 · 升级后无限使用</text></view><view style="height:200rpx"/></scroll-view><view class="buy-bar"><view class="buy-price-info"><view class="buy-plan-name"><text class="buy-plan-text">{{e}}会员</text></view><view class="buy-price-row"><text class="buy-price-unit">¥</text><text class="buy-price">{{f}}</text><text class="buy-original">原价¥{{g}}</text></view></view><view class="{{['buy-btn', i && 'btn-disabled']}}" bindtap="{{j}}"><text class="buy-btn-text">{{h}}</text></view></view></view>