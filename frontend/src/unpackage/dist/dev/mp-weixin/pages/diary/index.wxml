<view class="diary-page"><view class="diary-header"><text class="header-title">情绪日记</text><view class="add-btn" bindtap="{{a}}"><text>+ 记录今天</text></view></view><scroll-view class="diary-list" scroll-y><view wx:if="{{b}}" class="loading-tip"><text>加载中...</text></view><view wx:elif="{{c}}" class="empty-tip"><text class="empty-emoji">📖</text><text class="empty-text">还没有日记</text><text class="empty-desc">记录今天的心情，让 AI 陪你整理情绪</text></view><view wx:for="{{d}}" wx:for-item="diary" wx:key="k" class="diary-card" bindtap="{{diary.l}}"><view class="diary-card-header"><view class="diary-date-area"><text class="diary-date">{{diary.a}}</text><text wx:if="{{diary.b}}" class="diary-weather">{{diary.c}}</text></view><view wx:if="{{diary.d}}" class="emotion-badge"><text>{{diary.e}}</text><text class="emotion-label">{{diary.f}}</text></view></view><text wx:if="{{diary.g}}" class="diary-preview" numberOfLines="{{2}}">{{diary.h}}</text><view wx:if="{{diary.i}}" class="ai-summary-preview"><text class="ai-badge">✨ AI 总结</text><text class="ai-summary-text" numberOfLines="{{1}}">{{diary.j}}</text></view></view></scroll-view><view wx:if="{{e}}" class="editor-overlay" bindtap="{{n}}"><view class="editor-panel" catchtap="{{m}}"><view class="editor-header"><text class="editor-title">记录今天</text><text class="editor-close" bindtap="{{f}}">✕</text></view><text class="section-label">今天的情绪</text><scroll-view class="emotion-scroll" scroll-x><view class="emotion-row"><view wx:for="{{g}}" wx:for-item="e" wx:key="c" class="{{['emotion-pill', e.d && 'emotion-selected']}}" bindtap="{{e.e}}"><text class="emotion-pill-emoji">{{e.a}}</text><text class="emotion-pill-label">{{e.b}}</text></view></view></scroll-view><text class="section-label">今天的天气</text><view class="weather-row"><text wx:for="{{h}}" wx:for-item="w" wx:key="b" class="{{['weather-pill', w.c && 'weather-selected']}}" bindtap="{{w.d}}">{{w.a}}</text></view><text class="section-label">写下来...</text><block wx:if="{{r0}}"><textarea class="diary-textarea" placeholder="今天发生了什么？有什么想说的？" placeholder-style="{{'color: #5a5070; font-size: 28rpx'}}" auto-height="{{true}}" max-height="{{200}}" value="{{i}}" bindinput="{{j}}"/></block><button class="save-btn" loading="{{k}}" bindtap="{{l}}"> 保存日记 </button></view></view><view wx:if="{{o}}" class="detail-overlay" bindtap="{{D}}"><view class="detail-panel" catchtap="{{C}}"><view class="detail-header"><view class="detail-date-emotion"><text class="detail-date">{{p}}</text><text wx:if="{{q}}" class="detail-emotion">{{r}} {{s}}</text></view><text bindtap="{{t}}">✕</text></view><scroll-view class="detail-content" scroll-y><text wx:if="{{v}}" class="detail-text">{{w}}</text><view class="ai-section"><view class="ai-section-header"><text class="ai-section-title">✨ AI 情绪总结</text><text wx:if="{{x}}" class="get-summary-btn" bindtap="{{z}}">{{y}}</text></view><text wx:if="{{A}}" class="ai-summary-full">{{B}}</text><text wx:else class="ai-summary-placeholder"> 点击「获取总结」，让 AI 帮你梳理今天的情绪 🌙 </text></view></scroll-view></view></view></view>