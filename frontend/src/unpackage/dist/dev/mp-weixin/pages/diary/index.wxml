<view class="diary-page"><view class="diary-header"><view class="header-title-wrap"><text class="header-title">情绪日记</text><text class="header-subtitle">记录每一天的心情</text></view><view class="add-btn" bindtap="{{a}}"><text class="add-btn-icon">+</text><text class="add-btn-text">记录</text></view></view><scroll-view class="diary-list" scroll-y><view wx:if="{{b}}" class="state-tip"><text class="state-text">加载中…</text></view><view wx:elif="{{c}}" class="empty-state"><view class="empty-icon-wrap"><text class="empty-icon">📖</text></view><text class="empty-title">还没有日记</text><text class="empty-desc">记录今天的心情，让 AI 陪你整理情绪</text><view class="empty-action" bindtap="{{d}}"><text class="empty-action-text">+ 写第一篇日记</text></view></view><view wx:for="{{e}}" wx:for-item="diary" wx:key="o" class="diary-card" bindtap="{{diary.p}}"><view class="emotion-bar" style="{{'background:' + diary.a}}"/><view class="diary-card-body"><view class="diary-card-top"><view class="diary-meta"><text class="diary-date">{{diary.b}}</text><text wx:if="{{diary.c}}" class="diary-weather">{{diary.d}}</text></view><view wx:if="{{diary.e}}" class="emotion-badge" style="{{'background:' + diary.i + ';' + ('border-color:' + diary.j)}}"><text class="emotion-emoji">{{diary.f}}</text><text class="emotion-label" style="{{'color:' + diary.h}}">{{diary.g}}</text></view></view><text wx:if="{{diary.k}}" class="diary-preview" numberOfLines="{{2}}">{{diary.l}}</text><view wx:if="{{diary.m}}" class="ai-preview"><text class="ai-preview-badge">AI</text><text class="ai-preview-text" numberOfLines="{{1}}">{{diary.n}}</text></view></view></view><view style="height:80rpx"/></scroll-view><view wx:if="{{f}}" class="sheet-overlay" bindtap="{{p}}"><view class="sheet-panel" catchtap="{{o}}"><view class="sheet-handle"/><view class="sheet-header"><text class="sheet-title">记录今天</text><view class="close-btn" bindtap="{{g}}"><text class="close-icon">✕</text></view></view><text class="section-label">今天的情绪</text><scroll-view class="emotion-scroll" scroll-x><view class="emotion-row"><view wx:for="{{h}}" wx:for-item="e" wx:key="d" class="{{['emotion-pill', e.e && 'emotion-selected']}}" style="{{e.f}}" bindtap="{{e.g}}"><text class="emotion-pill-emoji">{{e.a}}</text><text class="emotion-pill-label" style="{{e.c}}">{{e.b}}</text></view></view></scroll-view><text class="section-label">今天的天气</text><view class="weather-row"><view wx:for="{{i}}" wx:for-item="w" wx:key="b" class="{{['weather-pill', w.c && 'weather-selected']}}" bindtap="{{w.d}}"><text class="weather-text">{{w.a}}</text></view></view><text class="section-label">写下来…</text><block wx:if="{{r0}}"><textarea class="diary-textarea" placeholder="今天发生了什么？有什么想说的？" placeholder-style="{{'color: rgba(180,170,200,0.3); font-size: 28rpx'}}" auto-height="{{true}}" max-height="{{200}}" value="{{j}}" bindinput="{{k}}"/></block><view class="{{['save-btn', m && 'btn-loading']}}" bindtap="{{n}}"><text class="save-btn-text">{{l}}</text></view></view></view><view wx:if="{{q}}" class="sheet-overlay" bindtap="{{G}}"><view class="sheet-panel detail-panel" catchtap="{{F}}"><view class="sheet-handle"/><view class="detail-header"><view class="detail-meta"><text class="detail-date">{{r}}</text><text wx:if="{{s}}" class="detail-emotion-badge">{{t}} {{v}}</text></view><view class="close-btn" bindtap="{{w}}"><text class="close-icon">✕</text></view></view><scroll-view class="detail-scroll" scroll-y><text wx:if="{{x}}" class="detail-text">{{y}}</text><view class="ai-section"><view class="ai-section-header"><view class="ai-section-title-wrap"><view class="ai-dot"/><text class="ai-section-title">AI 情绪总结</text></view><view wx:if="{{z}}" class="{{['get-summary-btn', B && 'btn-loading']}}" bindtap="{{C}}"><text class="get-summary-text">{{A}}</text></view></view><text wx:if="{{D}}" class="ai-summary-text">{{E}}</text><text wx:else class="ai-placeholder">点击「获取总结」，让 AI 帮你梳理今天的情绪 🌙</text></view><view style="height:40rpx"/></scroll-view></view></view></view>