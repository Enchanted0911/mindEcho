<view class="natal-page"><view class="bg-gradient"/><view wx:if="{{a}}" class="loading-screen"><view class="loading-orb"><view class="orb-ring r1"/><view class="orb-ring r2"/><view class="orb-ring r3"/><text class="orb-symbol">☉</text></view><text class="loading-text">{{b}}</text><text class="loading-sub">正在绘制你的宇宙地图</text></view><scroll-view wx:if="{{c}}" class="page-scroll" scroll-y><view class="form-header"><view class="form-icon-wrap"><text class="form-icon">☉</text></view><text class="form-title">本命盘</text><text class="form-desc">输入你的出生信息，探索属于你的星盘宇宙</text></view><view class="form-card"><text class="field-label">出生日期</text><view class="date-row"><picker class="date-picker" mode="selector" range="{{e}}" range-key="label" value="{{f}}" bindchange="{{g}}"><view class="picker-btn">{{d}}年</view></picker><picker class="date-picker" mode="selector" range="{{i}}" range-key="label" value="{{j}}" bindchange="{{k}}"><view class="picker-btn">{{h}}月</view></picker><picker class="date-picker" mode="selector" range="{{m}}" range-key="label" value="{{n}}" bindchange="{{o}}"><view class="picker-btn">{{l}}日</view></picker></view><text class="field-label" style="margin-top:28rpx">出生时间</text><view class="time-row"><picker class="time-picker" mode="selector" range="{{q}}" range-key="label" value="{{r}}" bindchange="{{s}}"><view class="picker-btn">{{p}}时</view></picker><picker class="time-picker" mode="selector" range="{{v}}" range-key="label" value="{{w}}" bindchange="{{x}}"><view class="picker-btn">{{t}}分</view></picker></view><text class="field-label" style="margin-top:28rpx">出生城市</text><view class="input-wrap"><text class="input-icon">📍</text><input class="city-input" placeholder="如：北京、上海、成都" placeholder-style="color:#4a3868" maxlength="20" value="{{y}}" bindinput="{{z}}"/></view></view><view class="tip-card"><text class="tip-icon">🌙</text><text class="tip-text">出生时间越精确，星盘越准确。若不确定具体时间，可使用中午12时作为参考。</text></view><view class="submit-btn" bindtap="{{A}}"><text class="submit-text">✦ 绘制我的星盘</text></view><view style="height:120rpx"/></scroll-view><view wx:if="{{B}}" class="result-page"><view class="chart-visual"><view class="chart-bg-glow"/><view class="chart-circle outer-circle"/><view class="chart-circle mid-circle"/><view class="chart-circle inner-circle"/><view wx:for="{{C}}" wx:for-item="i" wx:key="a" class="house-line" style="{{'transform:' + i.b}}"/><view wx:for="{{D}}" wx:for-item="p" wx:key="b" class="planet-marker" style="{{'transform:' + p.c + ';' + ('color:' + p.d)}}"><text class="planet-symbol-marker">{{p.a}}</text></view><view class="chart-center"><text class="chart-center-text">☉</text></view></view><view class="summary-row"><view class="summary-item"><text class="summary-label">☉ 太阳</text><text class="summary-val">狮子座</text></view><view class="summary-divider"/><view class="summary-item"><text class="summary-label">☽ 月亮</text><text class="summary-val">双鱼座</text></view><view class="summary-divider"/><view class="summary-item"><text class="summary-label">↑ 上升</text><text class="summary-val">天蝎座</text></view></view><view class="tabs-bar"><view class="{{['tab-item', E && 'active']}}" bindtap="{{F}}"><text>行星</text></view><view class="{{['tab-item', G && 'active']}}" bindtap="{{H}}"><text>相位</text></view><view class="{{['tab-item', I && 'active']}}" bindtap="{{J}}"><text>AI 解读</text></view></view><scroll-view class="tab-content" scroll-y><view wx:if="{{K}}"><view wx:for="{{L}}" wx:for-item="planet" wx:key="j" class="planet-row"><view class="planet-symbol-wrap" style="{{'background:' + planet.c + ';' + ('border-color:' + planet.d)}}"><text class="planet-symbol" style="{{'color:' + planet.b}}">{{planet.a}}</text></view><view class="planet-info"><text class="planet-name">{{planet.e}}</text><text class="planet-sign">{{planet.f}} · {{planet.g}}</text></view><view class="planet-bar-wrap"><view class="planet-bar" style="{{'width:' + planet.h + ';' + ('background:' + planet.i)}}"/></view></view></view><view wx:if="{{M}}"><view wx:for="{{N}}" wx:for-item="asp" wx:key="e" class="{{['aspect-row', asp.f]}}"><text class="asp-p1">{{asp.a}}</text><view class="{{['asp-badge', asp.c]}}"><text class="asp-symbol">{{asp.b}}</text></view><text class="asp-p2">{{asp.d}}</text></view></view><view wx:if="{{O}}" class="interpret-panel"><view class="focus-scroll-wrap"><scroll-view class="focus-scroll" scroll-x><view class="focus-list"><view wx:for="{{P}}" wx:for-item="opt" wx:key="c" class="{{['focus-chip', opt.d && 'focus-active']}}" bindtap="{{opt.e}}"><text class="focus-chip-icon">{{opt.a}}</text><text class="focus-chip-label">{{opt.b}}</text></view></view></scroll-view></view><view wx:if="{{Q}}" class="interpret-trigger" bindtap="{{R}}"><view class="trigger-glow"/><text class="trigger-icon">✦</text><text class="trigger-text">开始 AI 解读</text><text class="trigger-sub">由星屿 AI 为你解析</text></view><view wx:if="{{S}}" class="interpret-content"><view class="interpret-header"><text class="interpret-focus-label">{{T}} 解读</text><view wx:if="{{U}}" class="typing-indicator"><view class="typing-dot"/><view class="typing-dot"/><view class="typing-dot"/></view></view><text class="interpret-text">{{V}}</text></view><view wx:if="{{W}}" class="re-interpret-btn" bindtap="{{X}}"><text>↻ 换个角度解读</text></view></view><view style="height:160rpx"/></scroll-view><view class="result-actions"><view class="action-btn-outline" bindtap="{{Y}}"><text>重新计算</text></view><view class="action-btn-primary" bindtap="{{Z}}"><text>✦ AI 解读</text></view></view></view></view>