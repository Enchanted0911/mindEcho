<view class="transit-page"><view class="bg-gradient-t"/><view wx:if="{{a}}" class="loading-screen"><view class="loading-orbit"><view class="orbit-sun"><view class="sun-ring r1"/><view class="sun-ring r2"/><view class="sun-ring r3"/><text class="sun-sym">♄</text></view></view><text class="loading-text">{{b}}</text><text class="loading-sub">感应今日宇宙能量流动</text></view><scroll-view wx:if="{{c}}" class="page-scroll" scroll-y><view class="form-header"><view class="form-icon-wrap-t"><text class="form-icon-t">♄</text></view><text class="form-title">流运解读</text><text class="form-subtitle">{{d}}</text><text class="form-desc">当前天空的行星如何与你的星盘共鸣</text></view><view class="form-card"><text class="field-label">你的出生信息</text><view class="date-row"><picker mode="selector" range="{{f}}" range-key="label" value="{{g}}" bindchange="{{h}}"><view class="picker-btn-t">{{e}}年</view></picker><picker mode="selector" range="{{j}}" range-key="label" value="{{k}}" bindchange="{{l}}"><view class="picker-btn-t">{{i}}月</view></picker><picker mode="selector" range="{{n}}" range-key="label" value="{{o}}" bindchange="{{p}}"><view class="picker-btn-t">{{m}}日</view></picker><picker mode="selector" range="{{r}}" range-key="label" value="{{s}}" bindchange="{{t}}"><view class="picker-btn-t">{{q}}时</view></picker></view><view class="input-wrap-t"><text class="input-icon-t">📍</text><input class="city-input-t" placeholder="出生城市" placeholder-style="color:#4a3828" maxlength="20" value="{{v}}" bindinput="{{w}}"/></view></view><view class="submit-btn-t" bindtap="{{x}}"><text class="submit-text">♄ 感应今日流运</text></view><view style="height:120rpx"/></scroll-view><view wx:if="{{y}}" class="result-page"><view class="today-header"><view class="today-badge">今日</view><text class="today-date">{{z}}</text><view class="today-energy-badge"><text class="te-label">综合能量</text><text class="te-val">{{A}}%</text></view></view><view class="tabs-bar"><view class="{{['tab-item', B && 'active']}}" bindtap="{{C}}"><text>今日流运</text></view><view class="{{['tab-item', D && 'active']}}" bindtap="{{E}}"><text>流运事件</text></view><view class="{{['tab-item', F && 'active']}}" bindtap="{{G}}"><text>AI 解读</text></view></view><scroll-view class="tab-content" scroll-y><view wx:if="{{H}}"><text class="section-sub-title">能量分布</text><view class="energy-grid"><view wx:for="{{I}}" wx:for-item="val" wx:key="d" class="energy-cell"><text class="energy-key">{{val.a}}</text><view class="energy-ring-wrap"><view class="energy-ring" style="{{'background:' + val.c}}"><view class="energy-ring-inner"><text class="energy-pct">{{val.b}}</text></view></view></view></view></view><text class="section-sub-title" style="margin-top:32rpx">当前重点行星</text><view wx:for="{{J}}" wx:for-item="h" wx:key="f" class="{{['highlight-card', h.g]}}"><view class="hc-symbol-wrap"><text class="hc-symbol">{{h.a}}</text></view><view class="hc-info"><view class="hc-title-row"><text class="hc-name">{{h.b}}</text><view class="{{['hc-aspect-badge', h.d]}}"><text class="hc-aspect">{{h.c}}</text></view></view><text class="hc-impact">{{h.e}}</text></view></view></view><view wx:if="{{K}}"><view wx:for="{{L}}" wx:for-item="ev" wx:key="j" class="{{['event-card', ev.k]}}"><view class="event-head"><view class="event-planets-row"><text class="event-planet">{{ev.a}}</text><view class="{{['event-aspect-badge', ev.c]}}"><text class="event-aspect">{{ev.b}}</text></view><text class="event-planet">{{ev.d}}</text></view><view class="{{['event-intensity', ev.f]}}"><text class="ei-text">{{ev.e}}</text></view></view><view class="event-meta"><text class="event-date">📅 {{ev.g}}</text><text class="event-duration">⏱ {{ev.h}}</text></view><text class="event-desc">{{ev.i}}</text></view></view><view wx:if="{{M}}" class="interpret-panel"><view class="interpret-type-list"><view wx:for="{{N}}" wx:for-item="t" wx:key="c" class="{{['itype-chip', t.d && 'itype-active']}}" bindtap="{{t.e}}"><text class="itype-icon">{{t.a}}</text><text class="itype-label">{{t.b}}</text></view></view><view wx:if="{{O}}" class="interpret-trigger" bindtap="{{P}}"><view class="trigger-glow-t"/><text class="trigger-icon">♄</text><text class="trigger-text">感应今日流运能量</text><text class="trigger-sub">AI 分析当前宇宙影响</text></view><view wx:if="{{Q}}" class="interpret-content"><view class="interpret-header"><text class="interpret-focus-label">{{R}}</text><view wx:if="{{S}}" class="typing-indicator"><view class="typing-dot"/><view class="typing-dot"/><view class="typing-dot"/></view></view><text class="interpret-text">{{T}}</text></view><view wx:if="{{U}}" class="re-interpret-btn" bindtap="{{V}}"><text>↻ 换个角度解读</text></view></view><view style="height:160rpx"/></scroll-view><view class="result-actions"><view class="action-btn-outline-t" bindtap="{{W}}"><text>重新计算</text></view><view class="action-btn-primary-t" bindtap="{{X}}"><text>♄ AI 解读流运</text></view></view></view></view>